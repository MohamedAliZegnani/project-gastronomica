# Project Gastronomica — Phase 9 environment
NODE_ENV=development

# Web
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# PostgreSQL (required for persistent accounts — falls back to memory if down)
DATABASE_URL=postgresql://gastronomica:gastronomica@localhost:5432/gastronomica
POSTGRES_USER=gastronomica
POSTGRES_PASSWORD=gastronomica
POSTGRES_DB=gastronomica
POSTGRES_PORT=5432
